# ── Jarvis .env.example ──────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# The .env file is in .gitignore and will NEVER be committed.
#
# Or just run Jarvis — if .env is missing, the setup wizard will open
# and create it for you automatically.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED ─────────────────────────────────────────────────────────────────────

# Groq API key (free) — https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# OpenRouter API key — https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# What Jarvis calls you
USER_NAME=YourName

# OPTIONAL ─────────────────────────────────────────────────────────────────────

# Gmail address + App Password for send/read email skill
# How to create an App Password: Google Account → Security → App Passwords
EMAIL_ADDRESS=your.email@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Porcupine wake-word key (optional, free tier available)
# If left blank, Jarvis uses Whisper-based wake detection instead.
# Get a key at: https://console.picovoice.ai/
PORCUPINE_KEY=

# Contacts for WhatsApp/messaging skill — JSON format
# Example: {"Mom": "+1234567890", "Dad": "+0987654321"}
CONTACTS_JSON={}
